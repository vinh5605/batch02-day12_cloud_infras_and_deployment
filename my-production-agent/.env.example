# Copy thành .env.local và điền giá trị thật.
# KHÔNG commit file .env.local lên Git.

# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true
INSTANCE_ID=instance-local

# App
APP_NAME=My Production Agent
APP_VERSION=1.0.0

# LLM (rỗng = dùng mock LLM)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Security — BẮT BUỘC thay trong production
AGENT_API_KEY=dev-key-change-me-in-production

# Rate limit & Budget
RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0

# Storage — rỗng = fallback in-memory (chỉ dev)
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=*
